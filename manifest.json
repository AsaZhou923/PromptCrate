{
  "manifest_version": 3,
  "name": "PromptCrate",
  "version": "0.0.0",
  "description": "Local-first prompt snippet inserter for web input fields. No account, no cloud.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "PromptCrate",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "commands": {
    "open-prompt-menu": {
      "suggested_key": {
        "default": "Ctrl+Shift+2",
        "mac": "Command+Shift+2"
      },
      "description": "Open PromptCrate"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}

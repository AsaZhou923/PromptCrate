{
  "name": "prompt-crate",
  "version": "0.0.0-phase10",
  "private": true,
  "type": "module",
  "description": "Local-first prompt snippet inserter for web input fields. No account, no cloud.",
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-watch.ps1",
    "build": "pnpm build:extension && pnpm build:content",
    "build:content": "vite build --config vite.content.config.ts",
    "build:extension": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "check": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "package:zip": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-release.ps1"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.14.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^8.1.0",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.1.9"
  }
}
